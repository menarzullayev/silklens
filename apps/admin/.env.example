# SilkLens admin panel — environment template.
# Copy to `.env.local` (gitignored) and fill in values before `pnpm dev`.

# --- NextAuth v5 ---------------------------------------------------------
# Run `openssl rand -base64 32` to generate a strong secret.
AUTH_SECRET="replace-me-in-local-env"
# Public URL of the admin panel (used by NextAuth for callback URLs).
AUTH_URL="http://localhost:3001"
# Trust the AUTH_URL host explicitly in non-prod.
AUTH_TRUST_HOST="true"

# --- Backend API ---------------------------------------------------------
# Browser-visible (public) base URL for the FastAPI service.
NEXT_PUBLIC_API_URL="http://localhost:8000"
# Server-only base URL — used by RSC fetches inside the Docker network.
API_INTERNAL_URL="http://localhost:8000"

# --- Default tenant ------------------------------------------------------
# Backend seeds the root tenant with this UUID; the admin uses it until a real
# tenant switcher is wired to the API.
NEXT_PUBLIC_DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"

# --- OAuth providers (SILK-0155) ----------------------------------------
# Google OAuth — create credentials at https://console.cloud.google.com/
#   Authorised redirect URI: http://localhost:3001/api/auth/callback/google
# Uncomment and fill in to enable Google sign-in on the login page.
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
#
# Apple OAuth — requires Apple Developer account & Service ID
# AUTH_APPLE_ID=""
# AUTH_APPLE_SECRET=""
#
# Telegram — not yet supported by the backend identity service.
# AUTH_TELEGRAM_BOT_TOKEN=""
