# SilkLens mobile — environment template.
# Copy this file to assets/.env before running (`cp assets/.env.example assets/.env`).
# The actual assets/.env is git-ignored.
#
# Per Project-Decisions §1 the user-facing name is dynamic from the admin
# panel; APP_NAME here is the *fallback* used only when the localization /
# tenant branding fetch fails.

APP_NAME=SilkLens
APP_ENV=local

# Backend base URL.
# Android emulator: http://10.0.2.2:8000 (host loopback)
# iOS simulator:    http://localhost:8000
# Physical device:  http://<your-LAN-ip>:8000
API_BASE_URL_ANDROID=http://10.0.2.2:8000
API_BASE_URL_IOS=http://localhost:8000
API_BASE_URL_OVERRIDE=

# Sentry DSN. Leave empty in local dev.
SENTRY_DSN=

# Mapbox / Google Maps keys (FAZA 2). Empty for now.
MAPBOX_PUBLIC_TOKEN=
GOOGLE_MAPS_API_KEY_ANDROID=
GOOGLE_MAPS_API_KEY_IOS=

# Feature flags (overridable by admin remote config at runtime).
ONBOARDING_VARIANT=C
DEFAULT_LOCALE=uz
