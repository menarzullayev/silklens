# SilkLens — local dev environment template
# Copy to .env and adjust. Never commit .env to git.

# --- Service ---
SILKLENS_ENV=dev
SILKLENS_LOG_LEVEL=INFO

# --- Postgres (host port 5434 to avoid clashes with other local stacks) ---
SILKLENS_DATABASE_URL=postgresql+psycopg://silklens:silklens_dev@localhost:5434/silklens
SILKLENS_DATABASE_ECHO=false

# --- Redis (host port 6381 to avoid clashes with other local stacks) ---
SILKLENS_REDIS_URL=redis://localhost:6381/0

# --- MinIO ---
SILKLENS_MINIO_ENDPOINT=localhost:9000
SILKLENS_MINIO_ACCESS_KEY=silklens
SILKLENS_MINIO_SECRET_KEY=silklens_dev_minio
SILKLENS_MINIO_SECURE=false

# --- Elasticsearch ---
SILKLENS_ELASTICSEARCH_URL=http://localhost:9200

# --- Redpanda / Kafka ---
SILKLENS_KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# --- Auth ---
# Generate prod secret: openssl rand -base64 64
SILKLENS_JWT_SECRET=dev-only-secret-replace-in-production-min-32-chars
SILKLENS_JWT_ALGORITHM=HS256
SILKLENS_AUDIT_HMAC_KEY=dev-only-audit-hmac-key-replace-via-kms

# --- Email provider selector ---
# "resend" (default) or "brevo" — switch with no code change.
# Falls back to StubEmailClient when the selected provider has no credentials.
SILKLENS_EMAIL_PROVIDER=resend

# Sender display name + address (used by all providers).
# • Resend without custom domain  → SilkLens <onboarding@resend.dev>
# • Brevo: must match a verified sender in Brevo dashboard
# • After SILK-0010               → SilkLens <no-reply@silklens.app>
SILKLENS_EMAIL_FROM=SilkLens <onboarding@resend.dev>
SILKLENS_EMAIL_OTP_TTL_SECONDS=600

# --- Resend (https://resend.com, free: 3 000/mo, 100/day) ---
# Dashboard → API Keys → Create API Key
SILKLENS_RESEND_API_KEY=

# --- Brevo SMTP relay (free: 9 000/mo, 300/day) ---
# Dashboard → Settings → SMTP & API → SMTP tab
SILKLENS_BREVO_SMTP_LOGIN=
SILKLENS_BREVO_SMTP_PASSWORD=

# --- OpenAI (TTS audio guides + Whisper voice input — interim until GPU Kokoro/Piper) ---
# Leave blank to fall back to MockTtsProvider.
SILKLENS_OPENAI_API_KEY=
SILKLENS_OPENAI_TTS_MODEL=tts-1

# --- DeepL (Translation — interim until GPU NLLB-200) ---
# Free-tier key ends with :fx (api-free.deepl.com). Pro keys use api.deepl.com.
# Uzbek/Kazakh/Turkmen are not supported by DeepL — those pairs fall through to NLLB mock.
# Leave blank to fall back to MockTranslationProvider.
SILKLENS_DEEPL_API_KEY=

# --- Facebook OAuth ---
# Create an app at developers.facebook.com → "Facebook Login" product.
# Required permissions: email, public_profile.
# Leave blank to keep the /v1/auth/facebook endpoint returning 503.
SILKLENS_FACEBOOK_APP_ID=
SILKLENS_FACEBOOK_APP_SECRET=

# --- Instagram OAuth (Basic Display API — part of Facebook Developer platform) ---
# Add the "Instagram Basic Display" product to your Facebook App.
# Copy the Instagram App ID and Secret from the Basic Display settings panel.
# Leave blank to keep the /v1/auth/instagram endpoint returning 503.
SILKLENS_INSTAGRAM_APP_ID=
SILKLENS_INSTAGRAM_APP_SECRET=

# --- Firebase / FCM (Push Notifications) ---
# Either paste full service-account JSON or set project_id + credentials path.
# Leave blank to use stub (dev/test).
SILKLENS_FIREBASE_PROJECT_ID=
SILKLENS_FIREBASE_CREDENTIALS_JSON=

# --- API ---
SILKLENS_API_HOST=0.0.0.0
SILKLENS_API_PORT=8000
SILKLENS_API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
