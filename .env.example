# SilkLens — local dev environment template
# Copy to .env and adjust. Never commit .env to git.

# --- Service ---
SILKLENS_ENV=dev
SILKLENS_LOG_LEVEL=INFO

# --- Postgres (host port 5434 to avoid clashes with other local stacks) ---
SILKLENS_DATABASE_URL=postgresql+psycopg://silklens:silklens_dev@localhost:5434/silklens
SILKLENS_DATABASE_ECHO=false

# --- Redis (host port 6381 to avoid clashes with other local stacks) ---
SILKLENS_REDIS_URL=redis://localhost:6381/0

# --- MinIO ---
SILKLENS_MINIO_ENDPOINT=localhost:9000
SILKLENS_MINIO_ACCESS_KEY=silklens
SILKLENS_MINIO_SECRET_KEY=silklens_dev_minio
SILKLENS_MINIO_SECURE=false

# --- Elasticsearch ---
SILKLENS_ELASTICSEARCH_URL=http://localhost:9200

# --- Redpanda / Kafka ---
SILKLENS_KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# --- Auth ---
# Generate prod secret: openssl rand -base64 64
SILKLENS_JWT_SECRET=dev-only-secret-replace-in-production-min-32-chars
SILKLENS_JWT_ALGORITHM=HS256
SILKLENS_AUDIT_HMAC_KEY=dev-only-audit-hmac-key-replace-via-kms

# --- API ---
SILKLENS_API_HOST=0.0.0.0
SILKLENS_API_PORT=8000
SILKLENS_API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
